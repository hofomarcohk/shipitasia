# ─────────────────────────────────────────────────────
# ShipItAsia v1 環境變數範本
#
# 用法：cp .env.example oms/.env  +  cp .env.example wms/.env
# 實際 secret 走 .env.dev / .env.prod（已 gitignore 排除）
# ─────────────────────────────────────────────────────

# ── Service identity ──────────────────────────────────
APP_NAME="ShipItAsia OMS"           # OMS 用此值；WMS 改成 "ShipItAsia WMS"
APP_ENV="dev"                       # dev / staging / prod
APP_URL="http://localhost:3002"     # OMS port 3002；WMS port 3001
WMS_URL="http://localhost:3001"     # OMS 用，WMS 不需要
SHIPPING_SERVICE_URL="http://localhost:3002"  # WMS 用，OMS 不需要

# ── DB / Cache ────────────────────────────────────────
MONGODB_URI="mongodb://localhost:27017/?replicaSet=rs0"
MONGODB_NAME="vw_sms"               # OMS：vw_sms；WMS：vw_wms
REDIS_URI="127.0.0.1"
REDIS_PORT="6379"
REDIS_PASSWORD=""

# ── Auth / JWT ────────────────────────────────────────
CMS_SECRET="CHANGE_ME_jwt_signing_secret"
CMS_JWT_EXPIRES_IN="1d"
PASSWORD_SALT=10

# ── Internal cross-service API (X-Internal-Sync) ──────
API_SECRET="CHANGE_ME_32_char_internal_sync_secret"   # 兩端必須一致
API_CMS_SECRET="CHANGE_ME"          # WMS 用，呼叫 OMS sync
WMS_API_KEY="CHANGE_ME"             # OMS 用，呼叫 WMS
WMS_API_SECRET="CHANGE_ME"
INCOMING_WMS_API_KEY="CHANGE_ME"

# ── v1 業務參數 ───────────────────────────────────────
DEFAULT_CURRENCY=HKD
HANDLING_FEE_PER_PACKAGE=5
DEFAULT_INBOUND_COUNTRY=JP
DEFAULT_OUTBOUND_COUNTRY=HK
WALLET_MIN_TOPUP=100

# ── 上傳設定 ──────────────────────────────────────────
UPLOADS_BASE_PATH=./uploads
TOPUP_PROOF_MAX_SIZE_MB=5
TOPUP_PROOF_ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf

# ── size_estimate 推算邊界（Phase 6 用，cm³）──────────
SIZE_ESTIMATE_SMALL_MAX=5000
SIZE_ESTIMATE_MEDIUM_MAX=30000

# ── Phase 1 加密 + Resend ─────────────────────────────
ENCRYPTION_KEY=""                   # base64 32 bytes，產生：openssl rand -base64 32
RESEND_API_KEY=""
RESEND_FROM_EMAIL="onboarding@resend.dev"
EMAIL_VERIFY_BASE_URL="http://localhost:3002/zh-hk/verify-email"
PASSWORD_RESET_BASE_URL="http://localhost:3002/zh-hk/reset-password"

# ── Phase 1 Google OAuth ──────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="http://localhost:3002/api/cms/auth/google/callback"

# ── v1 Mock env flags（dev/staging 全部 true）─────────
PHASE2_USE_MOCK_OAUTH=true
PHASE7_USE_MOCK_CARRIER=true
PHASE8_USE_MOCK_CARRIER=true
PHASE7_OUTBOUND_ENABLED=true        # Phase 7 落地後切 true
MOCK_FORCE_ALL_ERRORS=false         # 壓力測試 retry 邏輯時切 true

# ── Phase 2 carrier credentials（dev mock；prod 切真實）─
FUUFFY_OAUTH_CLIENT_ID=""           # 業主寄信 support@fuuffy.com 取得後填
FUUFFY_OAUTH_CLIENT_SECRET=""
YUN_EXPRESS_API_URL="http://omsapi.uat.yunexpress.com"
YUN_API_SOURCE_KEY=""

# ── Misc ──────────────────────────────────────────────
NEXT_PUBLIC_NO_STATIC_ROUTE="0"
NEXT_PUBLIC_APP_NAME="ShipItAsia"
NEXT_PUBLIC_CMS_USER_IDLE_MINUTE=30
NEXT_PUBLIC_MAX_BOX_NO=99
COOKIE_MAX_AGE=86400
ENABLE_CRON=true
